<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Liguei Gás Curitiba – Entrega Rápida de Gás</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --flame: #FF4C00;
      --flame-light: #FF7533;
      --dark: #0E0E0E;
      --dark2: #1A1A1A;
      --dark3: #242424;
      --gold: #F5A623;
      --white: #F8F5F0;
      --gray: #888;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Barlow', sans-serif;
      background: var(--dark);
      color: var(--white);
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 5%;
      background: rgba(14,14,14,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,76,0,0.15);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo-icon {
      width: 42px; height: 42px;
      background: var(--flame);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
    }

    .logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 26px;
      letter-spacing: 2px;
      line-height: 1;
    }

    .logo-text span { color: var(--flame); }

    nav { display: flex; gap: 32px; align-items: center; }

    nav a {
      color: var(--white);
      text-decoration: none;
      font-weight: 500;
      font-size: 15px;
      opacity: 0.8;
      transition: opacity 0.2s, color 0.2s;
    }
    nav a:hover { opacity: 1; color: var(--flame); }

    .btn-header {
      background: var(--flame);
      color: #fff;
      border: none;
      padding: 10px 24px;
      border-radius: 6px;
      font-family: 'Barlow', sans-serif;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
      letter-spacing: 0.5px;
    }
    .btn-header:hover { background: var(--flame-light); transform: translateY(-1px); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 120px 5% 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 70% 50%, rgba(255,76,0,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 90% 20%, rgba(245,166,35,0.08) 0%, transparent 60%),
        var(--dark);
    }

    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,76,0,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,76,0,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 620px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,76,0,0.12);
      border: 1px solid rgba(255,76,0,0.3);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 13px;
      font-weight: 600;
      color: var(--flame);
      margin-bottom: 28px;
      animation: fadeUp 0.6s ease both;
    }

    .badge::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--flame);
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }

    h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(56px, 8vw, 96px);
      line-height: 0.95;
      letter-spacing: 2px;
      animation: fadeUp 0.6s 0.1s ease both;
    }

    h1 .highlight {
      color: var(--flame);
      display: block;
    }

    .hero-sub {
      font-size: 18px;
      line-height: 1.6;
      color: rgba(248,245,240,0.7);
      margin: 24px 0 40px;
      max-width: 480px;
      animation: fadeUp 0.6s 0.2s ease both;
      font-weight: 400;
    }

    .hero-ctas {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      animation: fadeUp 0.6s 0.3s ease both;
    }

    .btn-primary {
      background: var(--flame);
      color: #fff;
      text-decoration: none;
      padding: 16px 36px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 30px rgba(255,76,0,0.35);
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 40px rgba(255,76,0,0.5);
    }

    .btn-outline {
      border: 2px solid rgba(248,245,240,0.25);
      color: var(--white);
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: border-color 0.2s, background 0.2s;
    }
    .btn-outline:hover {
      border-color: var(--flame);
      background: rgba(255,76,0,0.08);
    }

    .hero-stats {
      position: absolute;
      right: 5%;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 20px;
      z-index: 2;
      animation: fadeUp 0.6s 0.4s ease both;
    }

    .stat-card {
      background: var(--dark2);
      border: 1px solid rgba(255,76,0,0.15);
      border-radius: 14px;
      padding: 22px 28px;
      text-align: center;
      min-width: 160px;
    }

    .stat-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 46px;
      color: var(--flame);
      line-height: 1;
    }

    .stat-label {
      font-size: 12px;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 4px;
      font-weight: 600;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── STRIP ── */
    .strip {
      background: var(--flame);
      padding: 16px 5%;
      display: flex;
      justify-content: center;
      gap: 48px;
      flex-wrap: wrap;
    }

    .strip-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 14px;
      color: #fff;
      letter-spacing: 0.5px;
    }

    /* ── SECTION BASE ── */
    section { padding: 90px 5%; }

    .section-label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--flame);
      margin-bottom: 12px;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(36px, 5vw, 56px);
      letter-spacing: 1.5px;
      line-height: 1.05;
    }

    .section-title span { color: var(--flame); }

    /* ── PRODUTOS ── */
    #produtos { background: var(--dark2); }

    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      margin-top: 52px;
    }

    .product-card {
      background: var(--dark3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 36px 28px;
      position: relative;
      overflow: hidden;
      transition: border-color 0.25s, transform 0.25s;
      cursor: default;
    }

    .product-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--flame);
      transform: scaleX(0);
      transition: transform 0.3s;
      transform-origin: left;
    }

    .product-card:hover {
      border-color: rgba(255,76,0,0.3);
      transform: translateY(-4px);
    }

    .product-card:hover::before { transform: scaleX(1); }

    .product-card.featured {
      border-color: rgba(255,76,0,0.4);
      background: linear-gradient(135deg, #1e1212, #1a1a1a);
    }

    .featured-tag {
      position: absolute;
      top: 16px; right: 16px;
      background: var(--flame);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 4px;
    }

    .product-icon {
      font-size: 48px;
      margin-bottom: 20px;
      display: block;
    }

    .product-name {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .product-weight {
      color: var(--flame);
      font-weight: 700;
      font-size: 14px;
      margin-bottom: 14px;
    }

    .product-desc {
      color: rgba(248,245,240,0.55);
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 24px;
    }

    .product-price {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 40px;
      color: var(--white);
    }

    .product-price sup {
      font-family: 'Barlow', sans-serif;
      font-size: 18px;
      font-weight: 700;
      vertical-align: super;
    }

    .product-price .cents {
      font-size: 24px;
    }

    .btn-pedido {
      display: block;
      width: 100%;
      margin-top: 22px;
      padding: 13px;
      background: rgba(255,76,0,0.1);
      border: 1px solid rgba(255,76,0,0.3);
      color: var(--flame);
      border-radius: 8px;
      font-family: 'Barlow', sans-serif;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
      letter-spacing: 0.5px;
    }
    .btn-pedido:hover {
      background: var(--flame);
      color: #fff;
    }

    /* ── COMO FUNCIONA ── */
    #como-funciona { background: var(--dark); }

    .steps-wrapper {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 32px;
      margin-top: 56px;
      position: relative;
    }

    .step {
      position: relative;
      padding: 32px;
      background: var(--dark2);
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    .step-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 64px;
      color: rgba(255,76,0,0.12);
      position: absolute;
      top: 10px; right: 20px;
      line-height: 1;
    }

    .step-icon {
      font-size: 36px;
      margin-bottom: 18px;
    }

    .step-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 1px;
      margin-bottom: 10px;
    }

    .step-desc {
      font-size: 14px;
      color: rgba(248,245,240,0.55);
      line-height: 1.65;
    }

    /* ── REGIÕES ── */
    #regioes { background: var(--dark2); }

    .regioes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
      margin-top: 48px;
    }

    .regiao-tag {
      background: var(--dark3);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 8px;
      padding: 14px 18px;
      font-size: 14px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: border-color 0.2s, color 0.2s;
    }

    .regiao-tag:hover {
      border-color: rgba(255,76,0,0.4);
      color: var(--flame);
    }

    .regiao-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--flame);
      flex-shrink: 0;
    }

    /* ── DEPOIMENTOS ── */
    #depoimentos { background: var(--dark); }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
      margin-top: 52px;
    }

    .review-card {
      background: var(--dark2);
      border-radius: 14px;
      padding: 28px;
      border: 1px solid rgba(255,255,255,0.06);
      position: relative;
    }

    .stars {
      color: var(--gold);
      font-size: 16px;
      letter-spacing: 2px;
      margin-bottom: 14px;
    }

    .review-text {
      font-size: 15px;
      color: rgba(248,245,240,0.75);
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .review-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .avatar {
      width: 42px; height: 42px;
      border-radius: 50%;
      background: var(--flame);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px;
      color: #fff;
      flex-shrink: 0;
    }

    .author-name {
      font-weight: 700;
      font-size: 14px;
    }

    .author-bairro {
      font-size: 12px;
      color: var(--gray);
    }

    .quote-mark {
      position: absolute;
      top: 20px; right: 22px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 80px;
      color: rgba(255,76,0,0.07);
      line-height: 1;
    }

    /* ── CTA FAIXA ── */
    .cta-section {
      background: linear-gradient(135deg, #1a0800 0%, #0e0e0e 50%, #1a0800 100%);
      padding: 80px 5%;
      text-align: center;
      position: relative;
      overflow: hidden;
      border-top: 1px solid rgba(255,76,0,0.15);
      border-bottom: 1px solid rgba(255,76,0,0.15);
    }

    .cta-glow {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 300px;
      background: radial-gradient(ellipse, rgba(255,76,0,0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(38px, 5vw, 64px);
      letter-spacing: 2px;
      position: relative;
      z-index: 1;
    }

    .cta-title span { color: var(--flame); }

    .cta-sub {
      color: rgba(248,245,240,0.6);
      font-size: 17px;
      margin: 16px 0 36px;
      position: relative;
      z-index: 1;
    }

    .cta-actions {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .btn-wpp {
      background: #25D366;
      color: #fff;
      text-decoration: none;
      padding: 16px 36px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 24px rgba(37,211,102,0.3);
    }
    .btn-wpp:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(37,211,102,0.45);
    }

    .btn-tel {
      background: transparent;
      border: 2px solid rgba(255,76,0,0.4);
      color: var(--flame);
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 8px;
      font-weight: 700;
      font-size: 16px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: background 0.2s;
    }
    .btn-tel:hover { background: rgba(255,76,0,0.1); }

    /* ── FOOTER ── */
    footer {
      background: #090909;
      padding: 60px 5% 32px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 48px;
      margin-bottom: 48px;
    }

    .footer-brand p {
      font-size: 14px;
      color: rgba(248,245,240,0.5);
      line-height: 1.7;
      margin-top: 14px;
      max-width: 280px;
    }

    .footer-col h4 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 18px;
      letter-spacing: 1.5px;
      margin-bottom: 18px;
      color: var(--white);
    }

    .footer-col ul { list-style: none; }

    .footer-col ul li {
      margin-bottom: 10px;
    }

    .footer-col ul li a {
      color: rgba(248,245,240,0.5);
      text-decoration: none;
      font-size: 14px;
      transition: color 0.2s;
    }
    .footer-col ul li a:hover { color: var(--flame); }

    .footer-contact-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 14px;
      font-size: 14px;
      color: rgba(248,245,240,0.55);
    }

    .footer-contact-item .icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.06);
      padding-top: 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 13px;
      color: rgba(248,245,240,0.3);
    }

    /* ── FLOAT WPP ── */
    .float-wpp {
      position: fixed;
      bottom: 28px; right: 28px;
      z-index: 200;
      background: #25D366;
      width: 60px; height: 60px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 30px;
      text-decoration: none;
      box-shadow: 0 4px 24px rgba(37,211,102,0.5);
      transition: transform 0.2s;
      animation: bounceIn 0.8s 1s both;
    }
    .float-wpp:hover { transform: scale(1.1); }

    @keyframes bounceIn {
      from { opacity: 0; transform: scale(0.4); }
      70%  { transform: scale(1.15); }
      to   { opacity: 1; transform: scale(1); }
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero-stats { display: none; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 640px) {
      nav { display: none; }
      .footer-grid { grid-template-columns: 1fr; gap: 28px; }
      .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
      .hero-ctas { flex-direction: column; }
      .btn-primary, .btn-outline { justify-content: center; }
    }
  </style>
</head>
